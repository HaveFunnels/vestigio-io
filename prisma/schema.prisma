// ──────────────────────────────────────────────
// AnonymousLead — /lp/audit funnel state
//
// One row per visitor that starts the multi-step lead form on /lp/audit.
// Persists across the funnel so we can:
//   - Resume mid-step (refresh-tolerant)
//   - Cache the mini-audit result by domain (no double-crawl)
//   - Promote to a real User+Org+Env on checkout completion
//   - Cleanup expired drafts (cron, daily)
//
// Lifecycle: draft → auditing → audit_complete → checkout_started → converted
//                                                                  → expired (cron)
// ──────────────────────────────────────────────

model AnonymousLead {
  id               String  @id @default(cuid())
  email            String?
  domain           String? // normalized (no protocol, no trailing slash)
  organizationName String?
  businessModel    String? // ecommerce | lead_gen | saas | hybrid
  monthlyRevenue   Float? // parsed from "$50k" → 50000
  averageTicket    Float?
  conversionModel  String? // checkout | whatsapp | form | external
  phone            String?
  formData         String? @db.Text // JSON dump of remaining state for debug

  // Funnel state
  status           String  @default("draft") // draft | auditing | audit_complete | checkout_started | converted | expired | spam
  currentStep      Int     @default(1)
  miniAuditId      String? // FK to MiniAuditResult
  stripeSessionId  String?
  stripeCustomerId String?
  promotedToUserId String? // User created on checkout
  promotedToOrgId  String? // Organization created on checkout

  // Browser locale captured from Accept-Language header at lead creation.
  // Propagated to User.locale on promotion so findings are generated in
  // the customer's language from the very first audit cycle.
  locale String?

  // Anti-abuse signals (collected for the heuristic stack — no captcha)
  ipAddress       String?
  userAgent       String?   @db.Text
  formStartedAt   DateTime? // for time-on-form check
  behavioralScore Int? // 0-100, computed at submit
  honeypotTripped Boolean   @default(false)

  // Expiry — cleanup cron deletes rows older than expiresAt
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  miniAudit MiniAuditResult? @relation(fields: [miniAuditId], references: [id])

  @@index([email])
  @@index([domain])
  @@index([status, createdAt])
  @@index([expiresAt]) // cleanup cron
  @@index([ipAddress, createdAt]) // rate limiting
}

// ──────────────────────────────────────────────
// MiniAuditResult — cached mini-audit per domain
//
// Cached for 14 days. If a second lead comes in for the same domain
// within the cache window, we link it to the existing result instead
// of re-running the crawler. This kills 90% of the cost of spam attempts
// at the same domain.
// ──────────────────────────────────────────────

// ──────────────────────────────────────────────
// ProspectScan — admin-initiated shallow_plus audits
//
// Used by the Growth → Surface Scans admin tab. Sales/marketing run
// these against prospect domains to generate "look what we found about
// your site" outreach material. Each scan:
//
//   - Belongs to no organization (it's pre-customer outreach)
//   - Is identified by a random non-guessable shareToken so admins
//     can paste a public link in cold emails / LinkedIn DMs
//   - Runs the staged pipeline in shallow_plus mode (1 home + 5
//     critical pages, 15s budget — deeper than the /lp/audit shallow
//     but cheaper than a full audit)
//   - Stores 5 visible findings (deriveMiniAuditFindings extended to
//     handle the additional pages eventually) + landing preview
//   - Tracks who in the admin team initiated it (createdByUserId)
//
// Status lifecycle: pending → running → complete | failed
// ──────────────────────────────────────────────

model ProspectScan {
  id              String  @id @default(cuid())
  shareToken      String  @unique // random 32-char hex, used in /scans/[token]
  domain          String // normalized
  label           String? // optional display name (e.g. "Acme Corp")
  notes           String? @db.Text // private admin notes
  status          String  @default("pending") // pending | running | complete | failed
  createdByUserId String? // admin who initiated the scan

  // Result data (populated when status='complete')
  preview         String? @db.Text // JSON of LandingPreview
  visibleFindings String? @db.Text // JSON array of MiniFinding[5]
  blurredFindings String? @db.Text // JSON array of BlurredFinding[10]
  pagesScanned    Int     @default(0)
  durationMs      Int?
  errorMsg        String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  createdBy User? @relation(fields: [createdByUserId], references: [id])

  @@index([domain])
  @@index([shareToken])
  @@index([status, createdAt])
  @@index([createdByUserId, createdAt])
}

model MiniAuditResult {
  id              String   @id @default(cuid())
  domainHash      String   @unique // sha256(normalized_domain) for cache lookup
  domain          String // human-readable for admin/debug
  preview         String   @db.Text // JSON of LandingPreview
  visibleFindings String   @db.Text // JSON array of MiniFinding[5]
  blurredFindings String   @db.Text // JSON array of BlurredFinding[10]
  durationMs      Int
  computedAt      DateTime @default(now())
  expiresAt       DateTime // computedAt + 14d

  leads AnonymousLead[]

  @@index([domainHash])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────
// DashboardLayout — per-user customizable bento layout
//
// Wave Dashboard Phase 2: persists each user's customized widget
// arrangement so the bento layout survives reloads and devices.
//
// **Why per-user, not per-org:** the dashboard is the user's
// personal landing page. Two members of the same org can have
// completely different widgets and arrangements, the same way
// two people on the same team configure their VS Code differently.
// If a future version wants to support shared "team dashboards"
// they can be added as a separate model.
//
// **Why JSON, not normalized rows:** layout is opaque structured
// data — react-grid-layout coordinates plus widget instance ids.
// We never query inside it (there's no "find me users with widget
// X enabled" use case). JSON keeps the schema flat and lets us
// evolve the WidgetInstance shape without migrations.
//
// schemaVersion lets future migrations rewrite old layouts in
// place when widget ids are renamed or removed.
// ──────────────────────────────────────────────

model DashboardLayout {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  schemaVersion  Int      @default(1)
  // JSON: WidgetInstance[] from src/lib/dashboard/default-layout.ts
  layout         String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
}

// ──────────────────────────────────────────────
// UserAction — persisted remediation actions created from findings
//
// Born when a user completes the Verify-via-chat flow. The Action
// carries the remediation plan + a snapshot of the finding's impact
// at creation time so we can later compute attribution deltas
// ("since you fixed X, monthly revenue +$Y") against subsequent
// audit cycles.
//
// status lifecycle: pending → in_progress → done (or dismissed).
// verifiedViaConversationId points back at the chat where the
// verification happened — enables the product to show "verified
// via conversation N on date D" and reopen that thread.
// ──────────────────────────────────────────────
model UserAction {
  id              String @id @default(cuid())
  organizationId  String
  environmentId   String
  findingId       String
  createdByUserId String

  title                String
  description          String? @db.Text
  // JSON string[] — numbered remediation steps copied from the plan
  remediationSteps     String? @db.Text
  estimatedEffortHours Float?

  status String @default("pending") // pending | in_progress | done | dismissed

  verifiedViaConversationId String?
  verifiedAt                DateTime?
  doneAt                    DateTime?
  notes                     String?   @db.Text

  // Attribution baseline — snapshotted at creation so later cycles
  // can compute the delta ("this Action recovered $X/mo").
  baselineImpactMidpoint Float?
  baselineImpactMin      Float?
  baselineImpactMax      Float?
  baselineCycleRef       String?

  // Attribution confirmation — stamped by the post-cycle job when a
  // later cycle confirms the linked finding is resolved (either
  // changeClass='resolved' or the finding no longer appears with
  // its inference_key). Separates "claimed recovered" from
  // "confirmed recovered" in the money_recovered widget so the
  // headline doesn't inflate when a done status doesn't match
  // reality.
  verifiedResolvedAt   DateTime?
  verificationCycleRef String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment  Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  finding      Finding       @relation(fields: [findingId], references: [id], onDelete: Cascade)
  createdBy    User          @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  verifiedVia  Conversation? @relation(fields: [verifiedViaConversationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([environmentId, status])
  @@index([environmentId, status, verifiedResolvedAt])
  @@index([findingId])
  @@index([createdByUserId])
}

// ──────────────────────────────────────────────
// Product telemetry — in-app engagement tracking (3.16)
// ──────────────────────────────────────────────

model ProductEvent {
  id            String   @id @default(cuid())
  userId        String
  orgId         String
  environmentId String?
  event         String // page_view, feature_first_use, workspace_drill, finding_action, drawer_open, playbook_run
  properties    Json? // event-specific payload: { from, to, time_on_previous_ms, feature, finding_id, ... }
  pathname      String
  sessionId     String // client-generated per-tab
  createdAt     DateTime @default(now())

  @@index([orgId, event, createdAt])
  @@index([environmentId, createdAt])
  @@index([userId, event])
  @@index([createdAt]) // for 90-day retention pruning
}

// ──────────────────────────────────────────────
// Wave 3.12: Opportunity Tracking
//
// Persists opportunity status transitions across audit cycles.
// Without this, projectActions() would reset every opportunity
// back to 'identified' on each cycle run.
// ──────────────────────────────────────────────
model OpportunityTracking {
  id            String   @id @default(cuid())
  actionKey     String // matches ActionProjection.id (opportunity_key)
  environmentId String
  status        String // identified | sized | accepted | implemented | verified | archived
  updatedAt     DateTime @updatedAt
  updatedBy     String? // userId who last changed status

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([actionKey, environmentId])
  @@index([environmentId])
}

// ──────────────────────────────────────────────
// Cancel Survey — exit survey + save offer tracking
//
// One row per cancel attempt. Captures the exit reason,
// what save offer was shown, whether it was accepted, and
// when (if) the subscription was actually cancelled.
// Used for churn analytics and save-offer optimization.
// ──────────────────────────────────────────────

model CancelSurvey {
  id             String    @id @default(cuid())
  organizationId String
  reason         String // too_expensive | not_using | missing_feature | switching | technical | temporary | other
  freeText       String?
  offeredSave    String? // discount | pause | downgrade | support | roadmap | none
  acceptedSave   Boolean   @default(false)
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Wave 3.20 — Saved Views (Findings page)
//
// Persists user-customized filter presets for the Findings page.
// Each view stores its filter JSON, groupBy/sortBy preferences,
// and visual metadata (Phosphor icon name + hex accent color).
// Default views are seeded on first access (4 preset views).
// ──────────────────────────────────────────────

model SavedView {
  id            String   @id @default(cuid())
  userId        String
  environmentId String
  name          String
  icon          String? // Phosphor icon name: "Flame", "SealCheck", "SquaresFour", "ShieldCheck"
  color         String? // hex for tab accent
  filters       Json // { severity?, pack?, polarity?, verification?, change?, impact?, surface?, rootCause?, columns? }
  groupBy       String? // "workspace" | "severity" | "root_cause" | "surface" | "pack"
  sortBy        String   @default("impact_desc")
  layout        String   @default("table")
  isDefault     Boolean  @default(false)
  isShared      Boolean  @default(false)
  isPinned      Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([userId, environmentId])
  @@index([environmentId, isShared])
}

/// Persisted Copy Framework Lens audit result. One row per
/// (env, cycle, framework, pageUrl, locale) combination.
///
/// Pre-fix the audit results lived in an in-memory Map inside the API
/// route, which meant every dev restart and every Railway deploy
/// invalidated all 10 cached frameworks. Each first page open after a
/// deploy paid 10× Haiku calls (~10s of perceived loading). Persisting
/// here makes results survive process boundaries and lets multiple
/// server instances share the same cache via the DB.
///
/// Phase 1: written on-demand by the API route when an audit is generated.
/// Phase 2: pre-populated by audit-runner on COLD cycle completion only,
///          so warm/hot cycles don't pay the LLM cost. Stays stable for
///          a week between cold cycles.
model CopyFrameworkAudit {
  id            String   @id @default(cuid())
  environmentId String
  cycleId       String // cycle that produced this audit
  frameworkId   String // copy-frameworks.ts id: aida | pas | 4ps | bab | spin | fab | dos | pixar | quest | 4cs
  pageUrl       String // exact crawled URL the audit was run against
  pageSlot      String // computed page slot: home | pricing | features | about — denormalized so a UI hit can filter without re-running detectPageSlot
  locale        String // pt-BR | en | es | de
  criteria      Json // CriterionVerdict[] — { id, status, evidence, fix }
  scorePct      Int // 0–100 computed from criteria (pass=1, warn=0.5, fail=0, not_evaluated excluded)
  modelId       String? // which LLM produced the row (e.g. "haiku_4_5") for future replay/audit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, cycleId, frameworkId, pageUrl, locale])
  @@index([environmentId, locale]) // serve-latest-cycle-by-env-and-locale lookup
  @@index([cycleId]) // bulk read for a single cycle (audit-runner Phase 2)
}

/// Generic LLM result cache for any on-demand workspace LLM endpoint
/// that doesn't merit its own typed table. One row per
/// (env, cycle, purpose, keyHash, locale) — the keyHash is whatever
/// extra discriminator the caller needs (page URL, persona id, etc.)
/// hashed so the column stays bounded.
///
/// Used by pulse-summary, copy-tone, persona-rewrite,
/// test-recommendations. Each pre-fix kept its own in-memory Map
/// that evaporated on every Railway deploy — a customer's first
/// page view after a deploy paid for a fresh Haiku call instead of
/// reading the result the previous request had already produced.
/// Persisting here makes each (env, cycle, locale, key) bucket cost
/// exactly one Haiku call until a new cycle ships.
model LlmResultCache {
  id            String   @id @default(cuid())
  environmentId String
  cycleId       String // cycle this result was computed against
  /// Stable label for the LLM endpoint (e.g. "pulse_summary",
  /// "copy_tone", "persona_rewrite", "test_recommendations").
  /// Mirrors TokenCostLedger.purpose so observability can correlate.
  purpose       String
  /// Sha256 (hex) of the per-call discriminator: workspace name +
  /// finding-id-set for pulse, persona-id for rewrite, page URL for
  /// per-page calls, etc. Empty string when the (env, cycle, purpose,
  /// locale) tuple is sufficient.
  keyHash       String   @default("")
  locale        String   @default("en")
  /// Opaque JSON blob returned by the LLM endpoint. Shape is owned by
  /// the consumer — this column is intentionally untyped.
  payload       Json
  modelId       String? // 'haiku_4_5' | 'sonnet_4_6' | 'opus_4_6'
  costCents     Float    @default(0) // best-effort, derived from the same call's ledger entry when available
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, cycleId, purpose, keyHash, locale])
  @@index([environmentId, purpose, locale])
  @@index([cycleId])
}

/// Cross-cycle cache for LLM-derived analyses of page content (Wave
/// 19c). When an enricher (copy-micro-copy, copy-seo-tension,
/// pricing-psychology, etc.) processes a page and the underlying
/// copy hasn't changed since the prior cycle, the parsed assessment
/// is identical. This table keys on a content hash instead of a
/// cycleId, so the next cold cycle on havefunnels.com reuses the
/// $0.0001 Haiku call from last week instead of paying again.
///
/// Differs from LlmResultCache: that table is per-cycle dedupe (warm
/// reads within one audit window). This one is per-content-fingerprint
/// reuse across cycles — same input copy, same output, no LLM call.
///
/// The payload is the parsed assessment (the same JSON the enricher
/// would have written to Evidence.payload). The caller re-stamps it
/// with the current cycle's evidence keys before persisting.
model ContentEnrichmentCache {
  id            String   @id @default(cuid())
  environmentId String
  /// Stable label, same vocabulary as LlmCallContext.purpose +
  /// TokenCostLedger.purpose. e.g. "micro_copy", "copy_seo_tension",
  /// "pricing_psychology", "ad_message_match", "copy_localization".
  purpose       String
  /// Sha256 (hex) of the normalized prompt input. Each enricher owns
  /// its own normalization: typically a concatenation of extracted
  /// copy elements + truncated body text + any page-meta fields the
  /// prompt depends on. Whitespace and case are normalized so cosmetic
  /// edits don't bust the cache.
  contentHash   String
  locale        String   @default("en")
  /// Page URL the enrichment was computed for. Optional — multi-page
  /// enrichers (cross_page_copy) can omit it. Used for debugging and
  /// occasional manual eviction.
  pageUrl       String?
  /// Parsed assessment JSON, ready to drop into ContentEnrichmentPayload.
  payload       Json
  modelId       String? // 'haiku_4_5' typically
  costCents     Float    @default(0)
  /// Bumped on every cache hit so we can later identify high-value
  /// rows and tune eviction policy (currently: keep forever).
  hitCount      Int      @default(0)
  createdAt     DateTime @default(now())
  lastHitAt     DateTime @default(now())

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, purpose, contentHash, locale])
  @@index([environmentId, purpose])
  @@index([lastHitAt])
}

/// One row per environment, populated on the FIRST cold cycle and
/// (almost) never re-written. Holds the slow-changing "identity" of
/// the domain so the chat agent and downstream consumers can read a
/// few invariant facts without re-deriving them every cycle.
///
/// Wave 19c. Distinct from BusinessProfile (which is user-edited via
/// onboarding) and from PlatformIndicator evidence (which is a
/// per-cycle audit artifact). DomainFingerprint is the consolidated
/// "what do we know about this domain at large" snapshot.
///
/// Refresh policy: quarterly at most. The audit pipeline only writes
/// here when refreshedAt is null or older than ~90 days. Manual
/// refresh (e.g. customer migrated platforms) is supported by
/// clearing the row.
model DomainFingerprint {
  id            String   @id @default(cuid())
  environmentId String   @unique
  /// Deterministic regex hits from staged-pipeline.detectPlatforms.
  /// Saves a tiny amount of work on hot/warm cycles where this would
  /// otherwise re-run for no behavior change. Mostly here so the
  /// chat agent can answer "what platform are they on?" without
  /// querying Evidence.
  detectedPlatforms String[] @default([])
  /// Primary locale of the homepage at first audit. Derived from
  /// homepageParsed.lang. Stable for the lifetime of the site
  /// barring an explicit re-launch.
  primaryLocale String?
  /// Summary of robots.txt AI-bot directives at first audit. Shape:
  /// { allows: string[], blocks: string[], unknown_directives: string[] }.
  /// Already 7d-gated upstream, this row is just for chat access.
  aiBotPolicy   Json?
  /// LLM-classified industry vertical. Single Haiku call on first
  /// cold cycle; never re-run unless refreshedAt is bumped. The cost
  /// budget here is bounded — at most a few cents per customer per
  /// quarter — but the chat agent reads it on EVERY turn, so the
  /// per-turn savings (no inference from the domain name) repay it
  /// many times over.
  industry      String?
  industryConfidence Int? // 0-100 from the Haiku classifier
  /// When the industry classifier last ran. Null while still
  /// pending the first cold cycle.
  industryClassifiedAt DateTime?
  /// Wall-clock first cycle that ever populated this row. Used by
  /// the audit pipeline to decide "first ever" vs "refresh."
  firstAuditAt  DateTime @default(now())
  /// Bumped when any field in this row is rewritten. Quarterly
  /// refresh policy is enforced by comparing against this.
  refreshedAt   DateTime @default(now())

  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}
