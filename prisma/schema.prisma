// ──────────────────────────────────────────────
// Site Inventory — Websites + Pages + Relations
// ──────────────────────────────────────────────

model Website {
  id             String   @id @default(cuid())
  environmentRef String
  domain         String
  rootUrl        String
  isPrimary      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pages            PageInventoryItem[]
  surfaceRelations SurfaceRelation[]

  @@unique([environmentRef, domain])
  @@index([environmentRef])
}

model PageInventoryItem {
  id                       String    @id @default(cuid())
  websiteRef               String
  environmentRef           String
  normalizedUrl            String
  path                     String
  pathScope                String?
  pageType                 String // landing | product | category | checkout | cart | policy | support | blog | account | app | other
  tier                     String    @default("secondary") // primary | secondary | tertiary | excluded
  priority                 Int       @default(0)
  criticality              Int       @default(0)
  title                    String?
  statusCode               Int?
  freshnessState           String    @default("unknown") // fresh | stale | expired | unknown
  freshnessAge             Int? // seconds since last check
  // Multi-signal classification (User Journey Intelligence Layer)
  classifiedPageType       String? // resolved type from multi-signal voter (overrides pageType)
  classificationConfidence Int       @default(0) // 0-100 agreement ratio
  classificationSignals    String    @default("[]") @db.Text // JSON: [{ source, vote, weight }]
  // Orphan tracking: lastSeenCycleId is updated on every successful fetch.
  // removedAt is set when the page hasn't been seen for > 14 days (across
  // multiple cycles) — soft-delete marker. Re-discovery clears it.
  lastSeenCycleId          String?
  removedAt                DateTime?
  // Wave 9.3 — per-URL audit trail. discoverySource records where the
  // URL was first surfaced (homepage_link, sitemap, critical_path, …).
  // skipReason is set when we discovered the URL but decided not to
  // persist a fetch result; the UI renders it next to the status so
  // the customer can tell "we never got there" apart from "the page
  // is broken".
  discoverySource          String?
  skipReason               String?
  // Wave 9.3 — detected A/B test platform on this page (optimizely,
  // vwo, google_optimize, …). null when none detected.
  abTestPlatform           String?
  // Wave 9.3 — locale advertised by the page (from <html lang="…">).
  // E.g. "en", "en-US", "pt-BR". Lets the inventory group/filter
  // multi-locale variants surfaced via hreflang.
  localeCode               String?
  // Wave 15.3 — denormalized aggregates so /api/inventory doesn't have
  // to run 3 separate groupBy/scan queries (Evidence response_times,
  // Finding count, RawBehavioralEvent session_count). Each is updated
  // at the natural write moment instead of computed per-request:
  //   - lastResponseTimeMs: updated by audit-runner when persisting
  //     http_response evidence for this page
  //   - findingCount: bulk-updated when a cycle completes, per surface
  //   - sessionCount30d: bulk-updated by behavioral aggregation cron
  //   - aggregatesUpdatedAt: timestamp of last aggregate write — null
  //     means aggregates haven't been computed for this row yet
  lastResponseTimeMs       Int?
  findingCount             Int       @default(0)
  sessionCount30d          Int       @default(0)
  aggregatesUpdatedAt      DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  website Website @relation(fields: [websiteRef], references: [id], onDelete: Cascade)

  @@unique([environmentRef, normalizedUrl])
  @@index([websiteRef])
  @@index([environmentRef, pageType])
  @@index([environmentRef, classifiedPageType])
  @@index([environmentRef, tier])
  @@index([environmentRef, removedAt])
}

model SurfaceRelation {
  id           String   @id @default(cuid())
  websiteRef   String
  sourceUrl    String
  targetUrl    String
  relationType String // anchor | form_action | iframe_src | script_src | stylesheet_src | redirect | canonical_external | intent_target | runtime_navigation
  sourceHost   String
  targetHost   String
  isSameDomain Boolean  @default(true)
  confidence   Float    @default(1.0)
  cycleRef     String
  metadata     String   @default("{}") @db.Text // JSON
  createdAt    DateTime @default(now())

  website Website @relation(fields: [websiteRef], references: [id], onDelete: Cascade)

  @@index([websiteRef])
  @@index([sourceUrl])
  @@index([targetUrl])
  @@index([cycleRef])
}

model FunnelModel {
  id               String   @id @default(cuid())
  environmentRef   String   @unique
  modelType        String // ecommerce | saas | lead_gen | services | hybrid
  stageDefinitions String   @db.Text // JSON: [{ key, label, order, pageTypes[], color }]
  isAutoDetected   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

