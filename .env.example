# ──────────────────────────────────────────────
# Vestigio.io — Environment Configuration
#
# Copy this file to .env and fill in the values.
# Required variables are marked [REQUIRED].
# Optional ones can be left empty to disable that feature.
# ──────────────────────────────────────────────

# ── Core [REQUIRED] ──────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vestigio
SECRET=                        # NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
SITE_URL=http://localhost:3000
SITE_NAME=Vestigio
AUTHOR_NAME=

# ── Encryption [REQUIRED in production] ──────
VESTIGIO_SECRET_KEY=           # AES-256 key for stored credentials — generate with: openssl rand -hex 32

# ── Stripe [REQUIRED in production] ──────────
STRIPE_SECRET_KEY=             # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=         # whsec_... (from Stripe Dashboard > Webhooks)

# ── Email [REQUIRED in production] ────────────
EMAIL_SERVER_HOST=             # e.g. smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=                    # e.g. noreply@yourdomain.com

# ── OAuth [OPTIONAL — omit to disable] ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI [OPTIONAL] ────────────────────────────
OPENAI_API_KEY=

# ── Claude LLM Chat [REQUIRED in production] ─
ANTHROPIC_API_KEY=             # sk-ant-... (from console.anthropic.com)
VESTIGIO_LLM_ENABLED=true     # false = deterministic fallback, no Claude calls

# ── Redis [OPTIONAL — for distributed rate limiting] ─
REDIS_URL=                     # redis://... (Railway auto-injects this when Redis is added)

# ── Payments — Paddle [OPTIONAL] ─────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_API_URL=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# ── Payments — Lemon Squeezy [OPTIONAL] ──────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SIGNATURE=
LEMON_SQUEEZY_STORE_ID=

# ── Storage — Cloudflare R2 [OPTIONAL] ───────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
NEXT_PUBLIC_IMAGE_URL=

# ── CDN — Video Testimonials [OPTIONAL] ──────
NEXT_PUBLIC_CDN_URL=             # e.g. https://cdn.vestigio.io — serves video testimonials from R2

# ── CMS — Sanity [OPTIONAL] ──────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_PROJECT_TITLE=
SANITY_API_KEY=
SANITY_HOOK_SECRET=

# ── Search — Algolia [OPTIONAL] ──────────────
NEXT_PUBLIC_ALGOLIA_APPLICATION_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=  # search-only key, safe for frontend
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=

# ── Email Marketing — Mailchimp [OPTIONAL] ───
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_API_SERVER=

# ── Meta Ads Integration [OPTIONAL] ──────────
META_ADS_APP_ID=               # Facebook App ID (from developers.facebook.com)
META_ADS_APP_SECRET=           # Facebook App Secret
# Note: ads_read scope requires Advanced Access approval.
# In development mode, app admins/testers can use it without approval.

# ── Google Ads Integration [OPTIONAL] ────────
GOOGLE_ADS_DEVELOPER_TOKEN=    # From ads.google.com/aw/apicenter (takes 1-2 weeks approval)
GOOGLE_ADS_CLIENT_ID=          # OAuth client ID from Cloud Console
GOOGLE_ADS_CLIENT_SECRET=      # OAuth client secret from Cloud Console

# ── Admin ─────────────────────────────────────
ADMIN_EMAILS=                  # comma-separated list of admin emails

# ── Demo Mode [DEV ONLY — never set in prod] ─
# NEXT_PUBLIC_DEMO_MODE=true
