{
	"name": "vestigio",
	"version": "1.6.1",
	"private": true,
	"engines": {
		"node": ">=18.18.0"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "prisma generate && next build",
		"start": "next start",
		"stripe:listen": "stripe listen --forward-to http://localhost:3000/api/stripe/webhook",
		"check-format": "prettier --check .",
		"check-lint": "eslint . --ext ts --ext tsx --ext js",
		"check-style": "npm run check-format && npm run check-lint",
		"fix-format": "prettier --write .",
		"fix-lint": "eslint --fix .",
		"fix-style": "npm run fix-format && npm run fix-lint",
		"typecheck": "tsc --noEmit",
		"test": "npx tsx --test tests/all.test.ts",
		"test:all": "npx tsx --test tests/*.test.ts",
		"test-build": "npm run check-style && npm run typecheck && npm run build",
		"seed": "npx tsx prisma/seed.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.81.0",
		"@aws-sdk/client-s3": "^3.515.0",
		"@aws-sdk/s3-request-presigner": "^3.515.0",
