datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // PgBouncer mode: DATABASE_URL points to the pool (transaction mode);
  // DIRECT_URL points to Postgres directly. Prisma uses DIRECT_URL for
  // migrations + introspection (operations PgBouncer can't proxy
  // safely) and DATABASE_URL for runtime queries.
  // Falls back to DATABASE_URL when DIRECT_URL isn't set, so local dev
  // without PgBouncer still works unchanged.
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  // Prisma OpenTelemetry tracing is stable in 5.x and on by default
  // when @prisma/instrumentation is registered. We register it in
  // src/libs/otel.ts; no preview-feature flag needed.
}

// ──────────────────────────────────────────────
// Auth + User (existing boilerplate)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String
  name      String   @unique
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String?  @default("USER")
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                       String                  @id @default(cuid())
  name                     String?
  email                    String?                 @unique
  emailVerified            DateTime?
  image                    String?
  password                 String?
  passwordResetToken       String?                 @unique
  passwordResetTokenExp    DateTime?
  role                     String?                 @default("USER")
  adminRole                String? // super_admin, support, marketing, viewer, billing
  customerId               String?                 @unique @map(name: "customer_id")
  subscriptionId           String?                 @unique @map(name: "subscription_id")
  priceId                  String?                 @map(name: "price_id")
  currentPeriodEnd         DateTime?               @map(name: "current_period_end")
  locale                   String?                 @default("en") // en | de | pt-BR | es
  phone                    String? // E.164 format e.g. +5511999999999
  phoneVerified            DateTime?
  // ─── Paddle activation flow ───────────────────
  // billingEmail is the Paddle customer email and is set on /lp
  // conversion (promote-lead.ts). It's separate from `email` so the
  // customer can later link an OAuth account with a DIFFERENT email
  // without losing the invoicing address. Think of `email` as
  // "login email" and `billingEmail` as "invoice email".
  billingEmail             String?
  // activationToken is minted by promote-lead.ts on /lp conversion.
  // The user is "pending" until they visit /activate/:token and pick
  // an auth method (Google, GitHub, or password). Token is consumed
  // (set to null) on activation. One-time use.
  activationToken          String?                 @unique
  activationTokenExpiresAt DateTime?
  activatedAt              DateTime?
  // Product telemetry — feature adoption timestamps (3.16)
  firstChatAt              DateTime?
  firstActionAt            DateTime?
  firstVerifyAt            DateTime?
  firstWorkspaceDrillAt    DateTime?
  createdAt                DateTime                @default(now())
  accounts                 Account[]
  sessions                 Session[]
  apiKeys                  ApiKey[]
  invitation               Invitation[]
  memberships              Membership[]
  supportTickets           SupportTicket[]
  ticketReplies            TicketReply[]
  feedbacks                Feedback[]
  notificationPrefs        NotificationPreference?
  prospectScans            ProspectScan[]
  dashboardLayouts         DashboardLayout[]
  userActions              UserAction[]
  customMaps               CustomMap[]
  savedViews               SavedView[]
}

// ──────────────────────────────────────────────
// Notification preferences — per-user, per-channel + per-event
// ──────────────────────────────────────────────

model NotificationPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  // Channel toggles
  emailEnabled            Boolean  @default(true)
  smsEnabled              Boolean  @default(false)
  whatsappEnabled         Boolean  @default(false)
  // Event toggles
  alertOnPageDown         Boolean  @default(true)
  alertOnIncident         Boolean  @default(true)
  alertOnRegression       Boolean  @default(true)
  alertOnImprovement      Boolean  @default(false)
  newsletterSubscribed    Boolean  @default(true)
  productUpdates          Boolean  @default(true)
  alertOnVerifiedResolved Boolean  @default(true)
  alertOnDigest           Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Notification log — every send attempt for audit + retry visibility
// ──────────────────────────────────────────────

model NotificationLog {
  id         String    @id @default(cuid())
  userId     String?
  channel    String // email | sms | whatsapp
  event      String // page_down | incident | regression | newsletter | magic_link | etc.
  recipient  String // email or phone
  subject    String?
  status     String // sent | failed | skipped | delivered (delivery tracking only — don't use for read state)
  readAt     DateTime? // null = unread; set when user marks as read in bell UI. Separate from delivery status.
  provider   String    @default("brevo") // brevo | twilio | meta_whatsapp
  providerId String? // provider's message id (wamid for meta)
  errorMsg   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([providerId])
  @@index([userId, readAt]) // for efficient unread-count queries
}

// ──────────────────────────────────────────────
// Inbound messages — WhatsApp/SMS/email replies received from users.
// Used so customers can reply to alerts and the reply turns into a
// support ticket or conversation in the admin.
// ──────────────────────────────────────────────

model InboundMessage {
  id            String   @id @default(cuid())
  channel       String // whatsapp | sms | email
  provider      String // meta_whatsapp | brevo | ...
  providerMsgId String?  @unique // wamid / message-id (dedupe)
  fromAddress   String // phone (E.164) or email
  fromName      String?
  userId        String? // matched user (by phone) if known
  body          String   @db.Text
  mediaUrl      String?
  mediaMimeType String?
  repliedToTag  String? // the outbound notification tag this replies to
  ticketId      String? // if a support ticket was auto-created
  handled       Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([fromAddress, createdAt])
  @@index([userId, createdAt])
  @@index([handled, createdAt])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Vestigio SaaS — Organization + Multi-tenancy
// ──────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  ownerId     String
  plan        String    @default("vestigio") // vestigio | pro | max
  status      String    @default("pending") // pending | active | suspended
  orgType     String    @default("customer") // customer | demo | trial
  locale      String? // Platform language: en | pt-BR | es | de. Single source of truth for the org.
  currency    String? // ISO 4217: USD, BRL, EUR. Null = auto from org locale
  trialEndsAt DateTime? // only set when orgType="trial"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships             Membership[]
  environments            Environment[]
  businessProfile         BusinessProfile?
  businessProfileVersions BusinessProfileVersion[]
  auditCycles             AuditCycle[]
  usage                   Usage[]
  conversations           Conversation[]
  tokenLedger             TokenCostLedger[]
  orgInvites              OrgInvite[]
  credits                 OrgCredits?
  userActions             UserAction[]
  customMaps              CustomMap[]
  cancelSurveys           CancelSurvey[]

  @@index([orgType, status])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("owner") // owner | admin | member
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model OrgInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   @default("member") // admin | member | viewer
  status         String   @default("pending") // pending | accepted | expired | revoked
  token          String   @unique
  expiresAt      DateTime
  invitedBy      String // userId of the person who sent the invite
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([organizationId, status])
}

model Environment {
  id                   String    @id @default(cuid())
  organizationId       String
  domain               String
  landingUrl           String
  isProduction         Boolean   @default(true)
  // Wave 5 Fase 2: activation lifecycle
  activated            Boolean   @default(false) // true once the first cold full cycle has been dispatched
  lastAccessedAt       DateTime? // updated (1h-debounced) when an owner/member loads /app/*; drives inactivity pause
  continuousPaused     Boolean   @default(false) // true when >14d without access; cleared on next access, triggers catch-up cycle
  engagementScore      Int       @default(0) // 0-100, computed hourly by product telemetry cron (3.16)
  // User-supplied glob patterns to exclude from crawl (e.g. "/admin/*", "/staging/*", "*.pdf").
  // Applied at discovery + per-URL crawl gate. Empty array = no exclusions.
  crawlExcludePatterns String[]  @default([])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditCycles          AuditCycle[]
  findings             Finding[]
  actions              Action[]
  saasAccessConfig     SaasAccessConfig?
  integrations         IntegrationConnection[]
  // Wave 0.2: Raw behavioral events from the snippet for this env
  behavioralEvents     RawBehavioralEvent[]
  userActions          UserAction[]
  opportunityTrackings OpportunityTracking[]
  savedViews           SavedView[]
  copyFrameworkAudits  CopyFrameworkAudit[]
  llmResultCache       LlmResultCache[]
  contentEnrichmentCache ContentEnrichmentCache[]
  domainFingerprint    DomainFingerprint?

  @@index([activated, continuousPaused])
  @@index([lastAccessedAt])
}

model BusinessProfile {
  id                  String @id @default(cuid())
  organizationId      String @unique
  businessModel       String @default("ecommerce") // ecommerce | lead_gen | saas | hybrid
  monthlyRevenue      Float?
  averageOrderValue   Float?
  monthlyTransactions Int?
  conversionRate      Float?
  chargebackRate      Float?
  churnRate           Float?
  conversionModel     String @default("checkout") // checkout | whatsapp | form | external

  // Wave 3.10: ICP (Ideal Customer Profile) fields — optional, system
  // falls back to heuristic detection from site content when absent.
  icpDescription      String? // Free text: "CTOs at mid-market SaaS companies"
  targetIndustry      String? // "saas", "ecommerce", "fintech", "healthcare", etc.
  buyerSophistication String? // "technical" | "non_technical" | "mixed"

  // Timestamp the owner ticked "I own this domain" during onboarding.
  // Captured for legal/abuse posture if a domain is ever disputed.
  ownershipConfirmedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditCycle {
  id               String    @id @default(cuid())
  organizationId   String
  environmentId    String
  status           String    @default("pending") // pending | running | complete | failed
  cycleType        String    @default("full") // full | incremental | verification
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  // Partial-failure visibility. Set when a write step inside the cycle
  // throws — the heal cron and admin debugging UIs read this to know
  // *where* the run got stuck instead of just "running > 10min".
  lastError        String?
  lastErrorAt      DateTime?
  retryCount       Int       @default(0)
  // Wave 18z — heartbeat-on-claim model for orphan re-dispatch.
  // The worker writes NOW() here every WORKER_HEARTBEAT_MS while the
  // cycle is running. The heal cron uses heartbeat freshness instead
  // of createdAt to decide if a cycle is truly orphaned, eliminating
  // the race where a slow worker is about to claim a pending cycle
  // while the heal cron concurrently re-dispatches it.
  // Null for cycles created before this column existed — those fall
  // back to the legacy createdAt-based cutoff.
  lastHeartbeatAt  DateTime?
  // Wave 16 — cached ProjectionResult (findings + actions + workspaces +
  // change_report + maps) serialized to JSONB. Written by audit-runner
  // after projectAll completes. /api/projections + layout.tsx read this
  // directly to skip the synchronous recomputeAll() on every page load —
  // the main source of 502 OOM as Evidence table grew with Wave 13/14.
  // Null until the next audit completes; legacy MCP path serves as fallback.
  projectionsCache Json?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment  Environment     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  evidence     Evidence[]
  findings     Finding[]
  actions      Action[]
  snapshots    CycleSnapshot[]

  // Hottest read pattern: layout cache fast-path
  //   findFirst({ environmentId, status: 'complete' }, orderBy: completedAt desc)
  // and the impersonate guardrail
  //   count({ environmentId, status: 'running' }).
  // Both share a (environmentId, status, completedAt) order.
  @@index([environmentId, status, completedAt])
  // Heal cron + cycle-mode lookups: status + age scans across all envs.
  //   findMany({ status: 'running', createdAt: { lt: cutoff } })
  //   findMany({ status: 'pending', createdAt: { lt: cutoff } })
  @@index([status, createdAt])
  // Wave 18z — heal cron now also filters by heartbeat freshness for
  // running cycles. Compound index covers
  //   findMany({ status: 'running', lastHeartbeatAt: { lt: hbCutoff } }).
  @@index([status, lastHeartbeatAt])
  // Per-org dashboards / billing rollups.
  @@index([organizationId, createdAt])
}

// ──────────────────────────────────────────────
// CycleSnapshot — change detection input
//
// One row per call to recomputeAll(). Stores the JSON-serialized
// `decisions[]` and `signals[]` from the engine output, plus metadata
// (decision count, signal count, recompute duration). The next cycle
// loads the most recent snapshot for the same workspace+environment
// to feed `previous_snapshot` into recomputeAll(), which produces
// the `change_report` consumed by FindingProjection.change_class.
//
// PrismaSnapshotStore implements the SnapshotStore interface from
// packages/change-detection/snapshot-store.ts so legacy callers
// (in-memory) can be swapped one-for-one.
//
// Retention: keep the latest 10 snapshots per env (matches
// DEFAULT_RETENTION_COUNT). Older snapshots are pruned by cron.
// ──────────────────────────────────────────────

model CycleSnapshot {
  id                   String   @id @default(cuid())
  cycleRef             String // matches AuditCycle.id-derived ref string
  cycleId              String? // FK to AuditCycle when known
  workspaceRef         String
  environmentRef       String
  schemaVersion        Int      @default(1)
  // JSON: { cycle_ref, decisions: Decision[], signals: Signal[] }
  // Stored as text instead of Json column to keep cross-DB compat.
  snapshot             String   @db.Text
  decisionCount        Int
  signalCount          Int
  auditMode            String   @default("full") // full | incremental
  recomputeMs          Int? // duration of the recompute that produced this snapshot
  contentHash          String? // optional integrity check
  isBaseline           Boolean  @default(false)
  // Wave 7.2: Monthly revenue (in cents) from integration data at this cycle.
  // Null when no integration is connected. Used for cross-cycle revenue
  // correlation in the Revenue Recovery Tracker.
  revenueSnapshotCents Int?
  revenueSource        String? // shopify | stripe | nuvemshop | null
  createdAt            DateTime @default(now())

  cycle AuditCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([workspaceRef, environmentRef, createdAt])
  @@index([cycleId])
  @@index([isBaseline])
}

// ──────────────────────────────────────────────
// Finding — denormalized projection for query + cold-start rehydrate
//
// One row per FindingProjection produced by projectAll(). Stores the
// full projection JSON for cheap rehydration on cold start, plus a
// few denormalized columns for query patterns we need fast:
//
//   - inferenceKey + cycleId for change_class lookups
//   - environmentId + surface for /api/inventory finding_count per surface
//   - severity + polarity for filter/aggregation
//
// On cold start, ensureContext() can SKIP the full recompute pipeline
// and just rehydrate findings from the most recent cycle's rows.
// On audit completion, rows are upserted within the cycle scope.
// On cycle delete (cascade), findings are removed.
// ──────────────────────────────────────────────

model Finding {
  id                   String   @id @default(cuid())
  cycleId              String
  environmentId        String
  cycleRef             String // engine cycle_ref string for cross-cycle matching
  inferenceKey         String // stable key — used for change detection matching
  pack                 String // scale | revenue | chargeback | saas | behavioral
  severity             String // critical | high | medium | low | none
  polarity             String // negative | positive | neutral
  confidence           Int
  impactMin            Float
  impactMax            Float
  impactMidpoint       Float
  surface              String // e.g. /checkout — used by inventory join
  rootCause            String?
  changeClass          String? // regression | improvement | new_issue | resolved | stable_risk | null
  verificationMaturity String? // unverified | pending | partially | verified | degraded | stale | null
  // Wave 20.4 — Modelo B Finding lifecycle. Tracks cross-cycle state
  // transitions for the same (environmentId, inferenceKey, surface)
  // identity. Powers the "value caught" monthly report (Wave 21.5) by
  // making it a simple `WHERE status = 'resolved'` query.
  /// Lifecycle state: created | confirmed | stale | resolved | regressed
  status               String   @default("created")
  /// Bumped whenever status transitions. Distinct from createdAt
  /// (which marks when this row was persisted in this cycle).
  statusChangedAt      DateTime @default(now())
  /// Number of consecutive cycles this finding has been seen. Resets
  /// on resolved → regressed. Drives created → confirmed transition.
  cyclesSeen           Int      @default(1)
  // Full FindingProjection JSON for cheap rehydration on cold start
  projection           String   @db.Text
  createdAt            DateTime @default(now())

  cycle       AuditCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  environment Environment  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  userActions UserAction[]

  @@unique([cycleId, inferenceKey])
  @@index([environmentId, cycleId])
  @@index([environmentId, surface])
  @@index([environmentId, severity])
  @@index([cycleRef, inferenceKey])
  // Wave 20.4 — supports loadPriorFindings(env, inferenceKey, surface)
  // for cross-cycle lifecycle matching + status='resolved' value-caught
  // queries.
  @@index([environmentId, inferenceKey, surface])
  @@index([environmentId, status, statusChangedAt])
}

// ──────────────────────────────────────────────
// Wave 18t-B — Action as a relational table
//
// Mirrors the Finding pattern: indexed columns for SQL queries
// (severity / category / surface / cycle range filters, server-side
// pagination), plus a `projection` text column carrying the full
// ActionProjection JSON for cheap rehydration when the drawer opens.
//
// Before this wave, Actions lived only inside AuditCycle.projectionsCache,
// which meant /app/actions had to deserialize the whole cache blob
// per request and filter in JavaScript. Now both layers coexist:
// projectionsCache stays as a complete snapshot of the cycle, the
// `Action` table powers fast cross-cycle queries.
//
// Backward compat: cycles predating this table have no Action rows.
// API readers fall through to projectionsCache when the table is
// empty for a given cycleId.
// ──────────────────────────────────────────────

model Action {
  id                String   @id @default(cuid())
  cycleId           String
  environmentId     String
  cycleRef          String // engine cycle_ref for cross-cycle matching
  actionKey         String // ${decision_key}_primary | _secondary_N | _verify_N | compound chain ids
  // ${decision_key} stripped of the _primary/_secondary_N/_verify_N suffix.
  // Lets the dashboard dedupe MAX(impact) per group via a single SQL
  // GROUP BY (instead of the JS reduce in /app/actions/page.tsx).
  decisionKey       String
  category          String // incident | opportunity | verification | observation
  actionType        String // risk_mitigation | opportunity_capture | verification | observation
  severity          String // critical | high | medium | low | none
  impactMin         Float?
  impactMax         Float?
  impactMidpoint    Float?
  priorityScore     Int      @default(0)
  surface           String? // primary affected surface, if any (denormalized for index)
  // JSON-serialized string[] — the inferences that triggered this
  // action's hasActive(...) condition. Used by the projection layer
  // to look up per-secondary impact + catalog remediation_steps.
  inferenceKeysJson String?  @db.Text
  // Full ActionProjection JSON for cheap rehydration on drawer open
  projection        String   @db.Text
  createdAt         DateTime @default(now())

  cycle       AuditCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([cycleId, actionKey])
  @@index([environmentId, cycleId])
  @@index([environmentId, severity])
  @@index([environmentId, category])
  @@index([environmentId, surface])
  @@index([environmentId, decisionKey])
  @@index([cycleRef, actionKey])
}

// ──────────────────────────────────────────────
// Wave 0.2 — Behavioral Pixel Ingest
//
// Raw events from the first-party snippet (public/snippet/vestigio.js).
// One row per event. The Wave 0.3 worker queries by
// (envId, sessionId, processedAt IS NULL), reconstructs a
// RawBehavioralBatch[], and runs aggregateSession() per session.
//
// Privacy: the snippet promises no PII in payloads, but we also hash
// the IP (sha256(ip + day_salt)) so cross-day correlation isn't possible
// from this table alone. Retention: pruned by receivedAt after the
// Wave 0.3 worker has aggregated the session.
// ──────────────────────────────────────────────

model RawBehavioralEvent {
  id          String    @id @default(cuid())
  envId       String // matches Environment.id (data-env attribute)
  sessionId   String // snippet-generated session id
  eventType   String // page_view | route_change | cta_click | scroll_depth | ...
  url         String // canonical URL the event happened on
  occurredAt  DateTime // event timestamp from the snippet (client clock)
  receivedAt  DateTime  @default(now()) // server clock — authoritative for retention
  payload     String    @db.Text // JSON: full RawBehavioralEvent (type, ts, url, data)
  attribution String?   @db.Text // JSON: AttributionContext — only set on the first event of a batch
  ipHash      String? // sha256(ip + daily_salt) — daily-rotating, non-reversible
  userAgent   String? // truncated to 200 chars, no PII
  processedAt DateTime? // set by Wave 0.3 worker once aggregated into a SessionAggregate

  environment Environment @relation(fields: [envId], references: [id], onDelete: Cascade)

  @@index([envId, sessionId, processedAt])
  @@index([envId, sessionId, occurredAt])
  @@index([receivedAt])
  // Composite indexes for plan-based prune + Mode 2 funnel queries.
  // The table is converted to a TimescaleDB hypertable at deploy time
  // (scripts/setup-timescaledb.ts) with 7-day chunks partitioned by
  // receivedAt and compressed by envId. These indexes are preserved.
  @@index([envId, receivedAt])
  @@index([envId, occurredAt, eventType])
}

model CustomMap {
  id             String   @id @default(cuid())
  organizationId String
  creatorUserId  String
  name           String
  description    String?  @db.Text
  mapDefinition  String   @db.Text
  nodeCount      Int      @default(0)
  edgeCount      Int      @default(0)
  prompt         String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [creatorUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([creatorUserId])
}

model Usage {
  id             String   @id @default(cuid())
  organizationId String
  usageType      String // mcp_chat | mcp_tool | credits
  amount         Int      @default(1)
  period         String // YYYY-MM format
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, usageType, period])
}

// ──────────────────────────────────────────────
// SaaS Access Configuration — per environment
// ──────────────────────────────────────────────

model SaasAccessConfig {
  id                   String    @id @default(cuid())
  environmentId        String    @unique
  loginUrl             String    @default("")
  email                String?
  passwordEncrypted    String?   @db.Text
  authMethod           String    @default("unknown") // password | oauth | magic_link | unknown
  mfaMode              String    @default("unknown") // none | optional | required | unknown
  hasTrial             Boolean?
  requiresSeedData     Boolean?
  testAccountAvailable Boolean?
  activationGoal       String?
  primaryUpgradePath   String?
  lastVerifiedAt       DateTime?
  lastFailureReason    String?
  status               String    @default("unconfigured") // unconfigured | configured | verified | failed | expired | awaiting_manual_mfa
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Integration Connections — Shopify, Stripe, Meta, Google
// ──────────────────────────────────────────────

model IntegrationConnection {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  provider      String // shopify | stripe | meta_ads | google_ads
  config        String      @db.Text // encrypted JSON (store URL, access token, etc.)
  status        String      @default("pending") // pending | connected | error | disconnected
  syncError     String? // last sync error message
  syncMetadata  String?     @db.Text // non-sensitive JSON cached by poller (ad_spend_30d, currency, creative_count, etc.)
  installedAt   DateTime    @default(now())
  lastSyncedAt  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environmentId, provider])
  @@index([environmentId])
}

// ──────────────────────────────────────────────
// Admin Config — pricing + limits
// ──────────────────────────────────────────────

model PlatformConfig {
  id        String   @id @default(cuid())
  configKey String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Credits — per-org verification budget
//
// Two buckets tracked separately so monthly rollover only clears the
// plan-included portion:
//   purchasedBalance        — credits bought via Credit Packs. Never
//                             expire (carry across billing cycles).
//                             Decrements only after plan-included is
//                             exhausted for the cycle.
//   planConsumedThisCycle   — count of verifications paid for by the
//                             active subscription's monthly quota.
//                             Resets when cycleStartAt rolls over.
//
// PLAN_CREDITS (apps/platform/credits.ts) defines the plan-included
// quota by plan key; it's intentionally NOT on this model so admin
// can't silently change costs downstream of the entitlements code.
//
// CreditTransaction below is the audit trail for purchases and
// consumption; the unique paddleTransactionId column makes webhook
// re-delivery idempotent.
// ──────────────────────────────────────────────

model OrgCredits {
  id                    String   @id @default(cuid())
  organizationId        String   @unique
  purchasedBalance      Int      @default(0)
  planConsumedThisCycle Int      @default(0)
  cycleStartAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]
}

model CreditTransaction {
  id                  String   @id @default(cuid())
  orgCreditsId        String
  kind                String // "purchase" | "consume" | "refund" | "grant"
  amount              Int // positive delta; direction inferred from kind
  packKey             String? // "pack-50" | "pack-200" | "pack-500" — null for non-purchase rows
  paddleTransactionId String?  @unique
  note                String?
  createdAt           DateTime @default(now())

  orgCredits OrgCredits @relation(fields: [orgCreditsId], references: [id], onDelete: Cascade)

  @@index([orgCreditsId, createdAt])
}

// ──────────────────────────────────────────────
// Observability — Platform Error Tracking
// ──────────────────────────────────────────────

model PlatformError {
  id             String   @id @default(cuid())
  errorType      String // e.g. "TypeError", "PrismaClientKnownRequestError"
  message        String   @db.Text
  stackTrace     String?  @db.Text
  endpoint       String? // API route that threw
  method         String? // GET, POST, etc.
  statusCode     Int?
  userId         String?
  userEmail      String?
  organizationId String?
  requestBody    String?  @db.Text // sanitized payload
  correlationId  String?
  severity       String   @default("error") // error | warning | critical
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([errorType, createdAt])
  @@index([endpoint, createdAt])
  @@index([severity, resolved, createdAt])
}

// ──────────────────────────────────────────────
// Auth Event Logging — persistent audit trail
// ──────────────────────────────────────────────

model AuthEvent {
  id            String   @id @default(cuid())
  environmentId String
