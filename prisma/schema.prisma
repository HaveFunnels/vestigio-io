datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ──────────────────────────────────────────────
// Auth + User (existing boilerplate)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String
  name      String   @unique
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String?  @default("USER")
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String          @id @default(cuid())
  name                  String?
  email                 String?         @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  passwordResetToken    String?         @unique
  passwordResetTokenExp DateTime?
  role                  String?         @default("USER")
  adminRole             String? // super_admin, support, marketing, viewer, billing
  customerId            String?         @unique @map(name: "customer_id")
  subscriptionId        String?         @unique @map(name: "subscription_id")
  priceId               String?         @map(name: "price_id")
  currentPeriodEnd      DateTime?       @map(name: "current_period_end")
  locale                String?         @default("en") // en | de | pt-BR | es
  phone                 String? // E.164 format e.g. +5511999999999
  phoneVerified         DateTime?
  createdAt             DateTime        @default(now())
  accounts              Account[]
  sessions              Session[]
  apiKeys               ApiKey[]
  invitation            Invitation[]
  memberships           Membership[]
  supportTickets        SupportTicket[]
  ticketReplies         TicketReply[]
  feedbacks             Feedback[]
  notificationPrefs     NotificationPreference?
}

// ──────────────────────────────────────────────
// Notification preferences — per-user, per-channel + per-event
// ──────────────────────────────────────────────

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  // Channel toggles
  emailEnabled          Boolean  @default(true)
  smsEnabled            Boolean  @default(false)
  whatsappEnabled       Boolean  @default(false)
  // Event toggles
  alertOnPageDown       Boolean  @default(true)
  alertOnIncident       Boolean  @default(true)
  alertOnRegression     Boolean  @default(true)
  alertOnImprovement    Boolean  @default(false)
  newsletterSubscribed  Boolean  @default(true)
  productUpdates        Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Notification log — every send attempt for audit + retry visibility
// ──────────────────────────────────────────────

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  channel     String // email | sms | whatsapp
  event       String // page_down | incident | regression | newsletter | magic_link | etc.
  recipient   String // email or phone
  subject     String?
  status      String // sent | failed | skipped
  provider    String   @default("brevo") // brevo | nodemailer
  providerId  String? // provider's message id
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Vestigio SaaS — Organization + Multi-tenancy
// ──────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  ownerId     String
  plan        String    @default("vestigio") // vestigio | pro | max
  status      String    @default("pending") // pending | active | suspended
  orgType     String    @default("customer") // customer | demo | trial
  trialEndsAt DateTime? // only set when orgType="trial"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships             Membership[]
  environments            Environment[]
  businessProfile         BusinessProfile?
  businessProfileVersions BusinessProfileVersion[]
  auditCycles             AuditCycle[]
  usage                   Usage[]
  conversations           Conversation[]
  tokenLedger             TokenCostLedger[]

  @@index([orgType, status])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("owner") // owner | admin | member
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Environment {
  id             String   @id @default(cuid())
  organizationId String
  domain         String
  landingUrl     String
  isProduction   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditCycles      AuditCycle[]
  saasAccessConfig SaasAccessConfig?
}

model BusinessProfile {
  id                  String @id @default(cuid())
  organizationId      String @unique
  businessModel       String @default("ecommerce") // ecommerce | lead_gen | saas | hybrid
  monthlyRevenue      Float?
  averageOrderValue   Float?
  monthlyTransactions Int?
  conversionRate      Float?
  chargebackRate      Float?
  churnRate           Float?
  conversionModel     String @default("checkout") // checkout | whatsapp | form | external

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditCycle {
  id             String    @id @default(cuid())
  organizationId String
  environmentId  String
  status         String    @default("pending") // pending | running | complete | failed
  cycleType      String    @default("full") // full | incremental | verification
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment  Environment  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  evidence     Evidence[]
}

model Usage {
  id             String   @id @default(cuid())
  organizationId String
  usageType      String // mcp_chat | mcp_tool | credits
  amount         Int      @default(1)
  period         String // YYYY-MM format
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, usageType, period])
}

// ──────────────────────────────────────────────
// SaaS Access Configuration — per environment
// ──────────────────────────────────────────────

model SaasAccessConfig {
  id                   String    @id @default(cuid())
  environmentId        String    @unique
  loginUrl             String    @default("")
  email                String?
  passwordEncrypted    String?   @db.Text
  authMethod           String    @default("unknown") // password | oauth | magic_link | unknown
  mfaMode              String    @default("unknown") // none | optional | required | unknown
  hasTrial             Boolean?
  requiresSeedData     Boolean?
  testAccountAvailable Boolean?
  activationGoal       String?
  primaryUpgradePath   String?
  lastVerifiedAt       DateTime?
  lastFailureReason    String?
  status               String    @default("unconfigured") // unconfigured | configured | verified | failed | expired | awaiting_manual_mfa
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Admin Config — pricing + limits
// ──────────────────────────────────────────────

model PlatformConfig {
  id        String   @id @default(cuid())
  configKey String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Observability — Platform Error Tracking
// ──────────────────────────────────────────────

model PlatformError {
  id             String   @id @default(cuid())
  errorType      String // e.g. "TypeError", "PrismaClientKnownRequestError"
  message        String   @db.Text
  stackTrace     String?  @db.Text
  endpoint       String? // API route that threw
  method         String? // GET, POST, etc.
  statusCode     Int?
  userId         String?
  userEmail      String?
  organizationId String?
  requestBody    String?  @db.Text // sanitized payload
  correlationId  String?
  severity       String   @default("error") // error | warning | critical
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([errorType, createdAt])
  @@index([endpoint, createdAt])
  @@index([severity, resolved, createdAt])
}

// ──────────────────────────────────────────────
// Auth Event Logging — persistent audit trail
// ──────────────────────────────────────────────

model AuthEvent {
  id            String   @id @default(cuid())
  environmentId String
  correlationId String?
  eventType     String // auth_attempt_started | auth_attempt_success | auth_attempt_failed | auth_mfa_detected | auth_config_saved | auth_config_deleted
  level         String   @default("info") // info | warn | error
  outcome       String?
  durationMs    Int?
  message       String   @db.Text
  createdAt     DateTime @default(now())

  @@index([environmentId, createdAt])
  @@index([correlationId])
  @@index([eventType, createdAt])
}

// ──────────────────────────────────────────────
// Phase 20 — MCP Persistence Models
// ──────────────────────────────────────────────

model McpPromptEvent {
  id              String   @id @default(cuid())
  orgId           String
  inputHash       String
  quality         String // good | weak | misfire
  rewriteOffered  Boolean  @default(false)
  rewriteAccepted Boolean?
  inputLength     Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([quality, createdAt])
}

model McpSession {
  id             String    @id @default(cuid())
  orgId          String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  queriesUsed    Int       @default(0)
  playbookId     String?
  promptRewrites Int       @default(0)
  chainDepth     Int       @default(0)
  plan           String    @default("vestigio")

  @@index([orgId, startedAt])
}

model McpSuggestionClick {
  id             String   @id @default(cuid())
  orgId          String
  suggestionType String // question | action | navigation | chain | playbook
  suggestionText String   @db.Text
  createdAt      DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([suggestionType, createdAt])
}

model PlaybookRun {
  id             String    @id @default(cuid())
  orgId          String
  playbookId     String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  stepsCompleted Int       @default(0)
  totalSteps     Int       @default(0)
  status         String    @default("running") // running | completed | abandoned

  @@index([orgId, startedAt])
  @@index([playbookId, status])
}

model AnalysisJob {
  id              String   @id @default(cuid())
  environmentId   String
  organizationId  String
  status          String   @default("queued") // queued | running | complete | failed
  progress        Float    @default(0)
  stagesCompleted String   @default("[]") @db.Text // JSON array
  error           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([environmentId, status])
  @@index([organizationId, createdAt])
}

// ──────────────────────────────────────────────
// Change Detection — Versioned Snapshots
// ──────────────────────────────────────────────

model VersionedSnapshot {
  id             String   @id @default(cuid())
  cycleRef       String
  workspaceRef   String
  environmentRef String
  schemaVersion  Int      @default(1)
  snapshot       String   @db.Text // JSON — CycleSnapshot
  isBaseline     Boolean  @default(false)
  decisionCount  Int      @default(0)
  signalCount    Int      @default(0)
  auditMode      String   @default("full") // full | incremental
  recomputeMs    Int?
  contentHash    String?
  createdAt      DateTime @default(now())

  @@index([workspaceRef, environmentRef, createdAt])
  @@index([workspaceRef, environmentRef, isBaseline])
  @@index([cycleRef])
}

// ──────────────────────────────────────────────
// Governance — Suppression Rules
// ──────────────────────────────────────────────

model SuppressionRule {
  id           String    @id @default(cuid())
  scopeRef     String
  matchKey     String
  reason       String    @db.Text
  createdBy    String
  expiresAt    DateTime?
  reviewPolicy String    @default("manual") // manual | auto_expire | permanent
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([scopeRef, isActive])
  @@index([matchKey, isActive])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────
// Site Inventory — Websites + Pages + Relations
// ──────────────────────────────────────────────

model Website {
  id             String   @id @default(cuid())
  environmentRef String
  domain         String
  rootUrl        String
  isPrimary      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pages            PageInventoryItem[]
  surfaceRelations SurfaceRelation[]

  @@unique([environmentRef, domain])
  @@index([environmentRef])
}

model PageInventoryItem {
  id             String   @id @default(cuid())
  websiteRef     String
  environmentRef String
  normalizedUrl  String
  path           String
  pathScope      String?
  pageType       String // landing | product | category | checkout | cart | policy | support | blog | account | app | other
  tier           String   @default("secondary") // primary | secondary | tertiary | excluded
  priority       Int      @default(0)
  criticality    Int      @default(0)
  title          String?
  statusCode     Int?
  freshnessState String   @default("unknown") // fresh | stale | expired | unknown
  freshnessAge   Int? // seconds since last check
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  website Website @relation(fields: [websiteRef], references: [id], onDelete: Cascade)

  @@unique([environmentRef, normalizedUrl])
  @@index([websiteRef])
  @@index([environmentRef, pageType])
  @@index([environmentRef, tier])
}

model SurfaceRelation {
  id           String   @id @default(cuid())
  websiteRef   String
  sourceUrl    String
  targetUrl    String
  relationType String // anchor | form_action | iframe_src | script_src | stylesheet_src | redirect | canonical_external | intent_target | runtime_navigation
  sourceHost   String
  targetHost   String
  isSameDomain Boolean  @default(true)
  confidence   Float    @default(1.0)
  cycleRef     String
  metadata     String   @default("{}") @db.Text // JSON
  createdAt    DateTime @default(now())

  website Website @relation(fields: [websiteRef], references: [id], onDelete: Cascade)

  @@index([websiteRef])
  @@index([sourceUrl])
  @@index([targetUrl])
  @@index([cycleRef])
}

// ──────────────────────────────────────────────
// Business Profile Versioning
// ──────────────────────────────────────────────

model BusinessProfileVersion {
  id             String   @id @default(cuid())
  organizationId String
  version        Int
  profile        String   @db.Text // JSON — full BusinessProfile snapshot
  source         String // manual | inferred | system_default | migration
  changeSummary  String?  @db.Text
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, version])
  @@index([organizationId, createdAt])
}

// ──────────────────────────────────────────────
// LLM Chat — Conversations + Token Cost Tracking
// ──────────────────────────────────────────────

model Conversation {
  id                String    @id @default(cuid())
  organizationId    String
  userId            String
  environmentId     String?
  title             String?
  status            String    @default("active") // active | archived | deleted
  messageCount      Int       @default(0)
  totalCostCents    Float     @default(0)
  totalInputTokens  Int       @default(0)
  totalOutputTokens Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]
  tokenLedger  TokenCostLedger[]

  @@index([organizationId, status, updatedAt])
  @@index([userId, status, updatedAt])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant
  content        String   @db.Text // plain text (user) or JSON ContentBlock[] (assistant)
  model          String? // haiku_4_5 | sonnet_4_6 | opus_4_6
  inputTokens    Int?
  outputTokens   Int?
  costCents      Float?
  toolCalls      String?  @db.Text // JSON ToolCallRecord[]
  purpose        String? // core_chat | context_summary
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model TokenCostLedger {
  id                       String   @id @default(cuid())
  organizationId           String
  userId                   String
  conversationId           String?
  model                    String // haiku_4_5 | sonnet_4_6 | opus_4_6
  purpose                  String // input_guard | core_chat | output_classifier | context_summary
  inputTokens              Int      @default(0)
  outputTokens             Int      @default(0)
  cacheCreationInputTokens Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  costCents                Float    @default(0)
  latencyMs                Int?
  isToolUse                Boolean  @default(false)
  createdAt                DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, model, createdAt])
  @@index([organizationId, purpose, createdAt])
  @@index([conversationId])
}

model ChatFeedback {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  conversationId String?
  messageId      String?
  rating         String // positive | negative
  comment        String?  @db.Text // sanitized user comment
  messagePreview String?  @db.Text // first 200 chars of the rated message
  model          String? // which model generated the response
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([rating, createdAt])
}

// ──────────────────────────────────────────────
// Evidence Persistence — canonical observations
// ──────────────────────────────────────────────

model Evidence {
  id               String    @id @default(cuid())
  evidenceKey      String
  evidenceType     String
  subjectRef       String
  workspaceRef     String
  environmentRef   String
  pathScope        String?
  cycleRef         String
  observedAt       DateTime  @default(now())
  freshUntil       DateTime?
  freshnessState   String    @default("unknown")
  stalenessReason  String?
  sourceKind       String
  collectionMethod String
  qualityScore     Int       @default(50)
  payload          String    @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auditCycleId String?
  auditCycle   AuditCycle? @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)

  @@unique([cycleRef, evidenceKey])
  @@index([workspaceRef, environmentRef, createdAt])
  @@index([evidenceType, createdAt])
  @@index([cycleRef])
  @@index([subjectRef])
}

// ──────────────────────────────────────────────
// Newsletter Management
// ──────────────────────────────────────────────

model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  content        String    @db.Text
  audience       String    @default("all") // all | free | pro | max
  status         String    @default("draft") // draft | sending | sent | failed
  recipientCount Int?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// Marketing & Analytics
// ──────────────────────────────────────────────

model PageView {
  id          String   @id @default(cuid())
  sessionId   String
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  country     String?
  region      String?  // state / province
  city        String?
  lat         Float?   // latitude
  lng         Float?   // longitude
  ip          String?  // visitor IP (hashed or raw, for spam detection)
  device      String? // desktop | mobile | tablet
  browser     String?
  os          String?
  duration    Int? // seconds on page
  scrollDepth Float? // 0-1 percentage
  abVariant   String? // A/B test variant ID
  createdAt   DateTime @default(now())

  @@index([path, createdAt])
  @@index([sessionId])
  @@index([utmSource, createdAt])
  @@index([abVariant, createdAt])
  @@index([country, createdAt])
}

model MarketingEvent {
  id        String   @id @default(cuid())
  sessionId String
  eventType String // click, scroll_depth, cta_click, form_start, form_complete, signup, drop_off
  path      String
  target    String? // element identifier
  metadata  String?  @db.Text // JSON
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId])
  @@index([path, eventType])
}

model ABTest {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("draft") // draft | running | paused | completed
  startDate   DateTime?
  endDate     DateTime?
  variants    String    @db.Text // JSON array: [{id, name, weight, homepageId?}]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model HomepageVariant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  heroTitle    String?  @db.Text
  heroSubtitle String?  @db.Text
  ctaText      String?
  ctaUrl       String?
  isDefault    Boolean  @default(false)
  status       String   @default("draft") // draft | active | archived
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TrackingPixel {
  id        String   @id @default(cuid())
  name      String // Facebook, Google, Taboola, etc.
  type      String // facebook | google_analytics | google_ads | taboola | custom
  pixelId   String
  enabled   Boolean  @default(true)
  config    String?  @db.Text // JSON for extra config
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Audit Log
// ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String // org.suspend, org.reactivate, org.impersonate, pricing.update, config.update, user.delete, user.role_change, newsletter.send, alert.create, etc.
  targetType String? // organization, user, config, newsletter, alert
  targetId   String?
  targetName String?
  metadata   String?  @db.Text // JSON extra context
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// ──────────────────────────────────────────────
// Alerts & Thresholds
// ──────────────────────────────────────────────

model AlertRule {
  id            String       @id @default(cuid())
  name          String
  description   String?
  metric        String // error_rate, mcp_usage, health_check, org_over_limit, new_signup
  condition     String // gt, lt, eq (greater than, less than, equal)
  threshold     Float
  window        Int          @default(10) // minutes
  channel       String       @default("email") // email, whatsapp, both
  enabled       Boolean      @default(true)
  lastTriggered DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  events        AlertEvent[]
}

model AlertEvent {
  id           String    @id @default(cuid())
  ruleId       String
  rule         AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  value        Float // the actual metric value that triggered the alert
  message      String
  acknowledged Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([ruleId, createdAt])
  @@index([acknowledged, createdAt])
}

model UptimeCheck {
  id        String   @id @default(cuid())
  service   String // database, redis, mcp, api
  status    String // ok, degraded, down
  latencyMs Int?
  message   String?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
}

// ──────────────────────────────────────────────
// Support Tickets
// ──────────────────────────────────────────────

model SupportTicket {
  id        String   @id @default(cuid())
  name      String // submitter name
  email     String // submitter email
  userId    String? // null for anonymous / public form submissions
  subject   String
  message   String   @db.Text
  status    String   @default("open") // open, in_progress, resolved, closed, spam
  priority  String   @default("normal") // low, normal, high, urgent
  category  String   @default("general") // general, bug, feature, billing, security
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?         @relation(fields: [userId], references: [id])
  replies TicketReply[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([email])
}

model TicketReply {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String? // null for system messages
  authorName  String
  authorEmail String
  content     String   @db.Text
  isStaff     Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?         @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
}

// ──────────────────────────────────────────────
// Feedback (for admin consolidation)
// ──────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  userName  String?
  type      String   @default("general") // general, bug, feature, ux, performance
  category  String? // groupable category set by admin
  title     String?
  content   String   @db.Text
  rating    Int? // 1-5
  page      String? // which route the feedback is about
  status    String   @default("new") // new, reviewed, acknowledged, actioned, dismissed
  metadata  String?  @db.Text // JSON
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([type, status, createdAt])
  @@index([userId])
}
