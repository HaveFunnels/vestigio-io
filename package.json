		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-toggle": "^1.1.10",
		"@radix-ui/react-toggle-group": "^1.1.11",
		"@xyflow/react": "^12.10.1",
		"algoliasearch": "^4.22.1",
		"apexcharts": "^4.5.0",
		"axios": "^1.6.5",
		"bcrypt": "^5.1.1",
		"cheerio": "^1.0.0-rc.12",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"deepmerge": "^4.3.1",
		"framer-motion": "^12.38.0",
		"ioredis": "^5.10.1",
		"lucide-react": "^1.7.0",
		"next": "^15.2.4",
		"next-auth": "^4.24.5",
		"next-intl": "^3.26.5",
		"next-sanity": "^9.9.4",
		"next-themes": "^0.2.1",
		"nextjs-toploader": "^1.6.6",
		"nodemailer": "^6.9.8",
